{
  "version": 2,
  "sources": [
    {
      "id": "myfonts",
      "name": "MyFonts",
      "enabled": true,
      "base_url": "https://www.myfonts.com",
      "meta": {
        "favicon_url": "https://www.myfonts.com/cdn/shop/files/MyFonts_Favicon_small.png?v=1717748062"
      },
      "crawl": {
        "mode": "myfonts_api",
        "products_endpoint": "/products.json",
        "page_size": 100,
        "max_pages": 250,
        "incremental_flush_every": 10,
        "enable_debut_enrichment": true,
        "max_debut_checks": 5000,
        "debut_lookback_days": 90,
        "api_request_delay_seconds": 0.5,
        "detail_request_delay_seconds": 0.35,
        "enable_tech_specs_script_enrichment": true,
        "max_tech_specs_checks": 5000,
        "reuse_last_success_profile": false,
        "always_enrich_packages": true,
        "language_script_signal_mode": "strong",
        "browser_mode": false,
        "browser_headless": true,
        "browser_storage_state_path": "state/myfonts_storage_state.json"
      },
      "assets": {
        "download_image": true,
        "download_woff": true,
        "download_specimen_pdf": true,
        "max_downloads_per_run": 30,
        "download_for_all_releases": true
      }
    },
    {
      "id": "type_today",
      "name": "type.today",
      "enabled": true,
      "base_url": "https://type.today",
      "meta": {
        "favicon_url": "https://type.today/favicon/favicon-32x32.png"
      },
      "crawl": {
        "mode": "type_today_api",
        "api_base_url": "https://type.today",
        "fonts_endpoint": "/api/v1/fonts",
        "font_detail_endpoint_template": "/api/v1/fonts/{slug}",
        "authors_endpoint": "/api/v1/authors",
        "author_detail_endpoint_template": "/api/v1/authors/{slug}",
        "font_detail_include": "font_styles,custom_font_styles,font_tabs",
        "journal_url": "/ru/journal",
        "new_post_prefix": "Новый шрифт:",
        "page_size": 100,
        "max_pages": 0,
        "use_author_mapping": true,
        "include_full_raw": true,
        "request_delay_seconds": 0.05,
        "incremental_flush_every": 10
      },
      "assets": {
        "download_image": true,
        "download_woff": true,
        "download_specimen_pdf": true,
        "max_downloads_per_run": 30
      }
    },
    {
      "id": "futurefonts",
      "name": "Future Fonts",
      "enabled": true,
      "base_url": "https://www.futurefonts.com",
      "meta": {
        "favicon_url": "https://www.futurefonts.com/favicon.ico"
      },
      "crawl": {
        "mode": "futurefonts_activity",
        "activity_endpoint": "/api/v1/activity",
        "incremental_flush_every": 5,
        "max_pages_per_type": 220,
        "lookback_days": 30,
        "detail_fetch_limit": 40,
        "typeface_fetch_limit": 2500,
        "activity_retry_max_retries": 14,
        "activity_retry_base_delay_seconds": 2.0,
        "activity_request_delay_seconds": 0.8
      },
      "assets": {
        "download_image": true,
        "download_woff": true,
        "download_specimen_pdf": true,
        "max_downloads_per_run": 20
      }
    },
    {
      "id": "typenetwork",
      "name": "Type Network",
      "enabled": true,
      "base_url": "https://store.typenetwork.com",
      "meta": {
        "favicon_url": "https://store.typenetwork.com/icons/favicon-32x32.png"
      },
      "crawl": {
        "mode": "typenetwork_public_families",
        "api_base_url": "https://api.typenetwork.com",
        "families_endpoint": "/api/1/public/families/",
        "incremental_flush_every": 10,
        "foundries_endpoint": "/api/1/foundries/",
        "page_size": 200,
        "max_pages": 0,
        "ordering": "-released",
        "lookback_days": 0,
        "disable_date_cutoff": true,
        "script_id_map": {
          "160": "Arabic",
          "200": "Greek",
          "215": "Latin",
          "220": "Cyrillic",
          "315": "Devanagari",
          "345": "Kannada",
          "907": "Indic"
        },
        "enable_image_enrichment": true,
        "image_enrichment_limit": 0,
        "image_site_page_limit": 0
      },
      "assets": {
        "download_image": true,
        "download_woff": false,
        "download_specimen_pdf": false,
        "max_downloads_per_run": 0,
        "download_for_all_releases": true
      }
    },
    {
      "id": "contemporarytype",
      "name": "Contemporary Type",
      "enabled": true,
      "base_url": "https://contemporarytype.com",
      "meta": {
        "favicon_url": "https://contemporarytype.com/favicon.ico"
      },
      "crawl": {
        "mode": "contemporarytype_products",
        "api_base_url": "https://backend.contemporarytype.com",
        "products_endpoint": "/api_front/products",
        "detail_endpoint_template": "/api_front/product/{slug}?with-bundles",
        "enable_detail_enrichment": true,
        "detail_fetch_limit": 49,
        "incremental_flush_every": 10
      },
      "assets": {
        "download_image": false,
        "download_woff": false,
        "download_specimen_pdf": false,
        "max_downloads_per_run": 0
      }
    },
    {
      "id": "fontstand",
      "name": "Fontstand",
      "enabled": true,
      "base_url": "https://fontstand.com",
      "meta": {
        "favicon_url": "https://fontstand.com/favicon.ico"
      },
      "crawl": {
        "mode": "fontstand_catalog",
        "filteredfonts_url": "https://fontstand.com/fonts/filteredfonts",
        "page_size": 64,
        "request_delay_seconds": 0.5,
        "enable_new_releases_enrichment": true,
        "new_releases_rss_url": "https://fontstand.com/news/new-releases/rss",
        "new_releases_loadmore_url": "https://fontstand.com/news/new-releases/loadMore",
        "enable_scripts_enrichment": true,
        "enable_scripts_via_languages": true,
        "enable_category_enrichment": true,
        "enable_features_enrichment": true,
        "max_scripts_filters": 20,
        "max_category_filters": 0,
        "max_features_filters": 30,
        "enable_detail_enrichment": true,
        "detail_fetch_limit": 500,
        "detail_delay_seconds": 0.6,
        "incremental_flush_every": 100
      },
      "assets": {
        "download_image": false,
        "download_woff": false,
        "download_specimen_pdf": false,
        "max_downloads_per_run": 0
      }
    },
    {
      "id": "ilt",
      "name": "I Love Typography",
      "enabled": true,
      "base_url": "https://fonts.ilovetypography.com",
      "meta": {
        "favicon_url": "https://fonts.ilovetypography.com/favicon.ico"
      },
      "crawl": {
        "mode": "ilt_typesense",
        "api_host": "https://ikgq6me4n0p3u2bvp-1.a1.typesense.net",
        "api_key": "ADTXqWaiIiDoQupZsSjnEaTE6zcIidQb",
        "collection": "prod_FONTS",
        "per_page": 250,
        "max_pages": 10,
        "incremental_flush_every": 25,
        "request_delay_seconds": 0.3
      },
      "assets": {
        "download_image": true,
        "download_woff": false,
        "download_specimen_pdf": false,
        "max_downloads_per_run": 30
      }
    }
  ]
}
